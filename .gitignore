# OCaml build artifacts
*.cmi
*.cmo
*.cmx
*.o
*.a
*.cmxa
*.cmxs
*.cmt
*.cmti
*.annot

# Generated benchmark input data (recreated by build.deps.sh scripts)
*.data
with_deps/benchmarksgame/input*.txt

# Generated macrobenchmark outputs (produced by benchmark runs, not inputs)
macrobenchmarks/menhir/sysver.automaton
macrobenchmarks/menhir/sysver.conflicts
macrobenchmarks/menhir/sysver.ml
macrobenchmarks/coq/*.glob
macrobenchmarks/coq/.*.aux

# Dune build artifacts
_build/
_build-running/
.dune-workspace

# Benchmark binaries generated by running-ng convention
*-ocaml-local
*-ocaml-global
*-ocaml-*
*-oxcaml-*
markbench-runtime
infer/openssl-capture/

# Generic temporary/editor files
*~
.DS_Store